{
  "schemaVersion": 1,
  "name": "赤炎精灵",
  "author": "rullerzhou",
  "version": "1.0.0",
  "description": "A cute pixel-art flame spirit — fiery, tiny, and full of life",
  "license": "MIT",
  "viewBox": {
    "x": -15,
    "y": -25,
    "width": 45,
    "height": 45
  },
  "layout": {
    "contentBox": {
      "x": -4,
      "y": -3,
      "width": 23,
      "height": 20
    },
    "marginBox": {
      "x": -8,
      "y": -7,
      "width": 30,
      "height": 24
    },
    "centerX": 7.5,
    "baselineY": 17,
    "visibleHeightRatio": 0.55,
    "baselineBottomRatio": 0.05
  },
  "eyeTracking": {
    "enabled": true,
    "states": [
      "idle",
      "dozing",
      "mini-idle"
    ],
    "eyeRatioX": 0.489,
    "eyeRatioY": 0.45,
    "maxOffset": 3,
    "bodyScale": 0.33,
    "shadowStretch": 0.15,
    "shadowShift": 0.3,
    "ids": {
      "eyes": "eyes-js",
      "body": "body-js",
      "shadow": "shadow-js",
      "dozeEyes": "eyes-doze"
    },
    "shadowOrigin": "7.5px 14px"
  },
  "states": {
    "idle": [
      "flame-idle-follow.svg"
    ],
    "yawning": [
      "flame-idle-yawn.svg"
    ],
    "dozing": [
      "flame-idle-doze.svg"
    ],
    "collapsing": [
      "flame-collapse-sleep.svg"
    ],
    "thinking": [
      "flame-working-thinking.svg"
    ],
    "working": [
      "flame-working-typing.svg"
    ],
    "juggling": [
      "flame-working-juggling.svg"
    ],
    "sweeping": [
      "flame-working-sweeping.svg"
    ],
    "error": [
      "flame-error.svg"
    ],
    "attention": [
      "flame-happy.svg"
    ],
    "notification": [
      "flame-notification.svg"
    ],
    "carrying": [
      "flame-working-carrying.svg"
    ],
    "sleeping": [
      "flame-sleeping.svg"
    ],
    "waking": [
      "flame-wake.svg"
    ]
  },
  "workingTiers": [
    {
      "minSessions": 3,
      "file": "flame-working-building.svg"
    },
    {
      "minSessions": 2,
      "file": "flame-working-juggling.svg"
    },
    {
      "minSessions": 1,
      "file": "flame-working-typing.svg"
    }
  ],
  "jugglingTiers": [
    {
      "minSessions": 2,
      "file": "flame-working-building.svg"
    },
    {
      "minSessions": 1,
      "file": "flame-working-juggling.svg"
    }
  ],
  "idleAnimations": [
    {
      "file": "flame-idle-look.svg",
      "duration": 6500
    },
    {
      "file": "flame-working-thinking.svg",
      "duration": 14000
    }
  ],
  "displayHintMap": {
    "flame-working-building.svg": "flame-working-building.svg",
    "flame-working-typing.svg": "flame-working-typing.svg",
    "flame-working-juggling.svg": "flame-working-juggling.svg",
    "flame-working-thinking.svg": "flame-working-thinking.svg"
  },
  "timings": {
    "minDisplay": {
      "attention": 4000,
      "error": 5000,
      "sweeping": 5500,
      "notification": 2500,
      "carrying": 3000,
      "working": 1000,
      "thinking": 1000
    },
    "autoReturn": {
      "attention": 4000,
      "error": 5000,
      "sweeping": 300000,
      "notification": 2500,
      "carrying": 3000
    },
    "yawnDuration": 3000,
    "wakeDuration": 1500,
    "deepSleepTimeout": 600000,
    "mouseIdleTimeout": 20000,
    "mouseSleepTimeout": 60000
  },
  "hitBoxes": {
    "default": {
      "x": -1,
      "y": -2,
      "w": 17,
      "h": 16
    },
    "sleeping": {
      "x": -2,
      "y": 8,
      "w": 19,
      "h": 7
    },
    "wide": {
      "x": -3,
      "y": -4,
      "w": 21,
      "h": 18
    }
  },
  "wideHitboxFiles": [
    "flame-error.svg",
    "flame-notification.svg",
    "flame-working-building.svg"
  ],
  "sleepingHitboxFiles": [
    "flame-sleeping.svg",
    "flame-collapse-sleep.svg"
  ],
  "reactions": {
    "drag": {
      "file": "flame-react-drag.svg"
    },
    "clickLeft": {
      "file": "flame-react-left.svg",
      "duration": 2500
    },
    "clickRight": {
      "file": "flame-react-right.svg",
      "duration": 2500
    },
    "annoyed": {
      "file": "flame-react-annoyed.svg",
      "duration": 3500
    },
    "double": {
      "files": [
        "flame-react-double.svg",
        "flame-react-double-jump.svg"
      ],
      "duration": 3500
    }
  },
  "miniMode": {
    "supported": true,
    "offsetRatio": 0.486,
    "states": {
      "mini-idle": [
        "flame-mini-idle.svg"
      ],
      "mini-alert": [
        "flame-mini-alert.svg"
      ],
      "mini-happy": [
        "flame-mini-happy.svg"
      ],
      "mini-enter": [
        "flame-mini-enter.svg"
      ],
      "mini-peek": [
        "flame-mini-peek.svg"
      ],
      "mini-working": [
        "flame-mini-typing.svg"
      ],
      "mini-crabwalk": [
        "flame-mini-crabwalk.svg"
      ],
      "mini-enter-sleep": [
        "flame-mini-enter-sleep.svg"
      ],
      "mini-sleep": [
        "flame-mini-sleep.svg"
      ]
    },
    "timings": {
      "minDisplay": {
        "mini-alert": 4000,
        "mini-happy": 4000
      },
      "autoReturn": {
        "mini-alert": 4000,
        "mini-happy": 4000
      }
    },
    "glyphFlips": {
      "pixel-z": 4,
      "pixel-z-small": 3
    }
  },
  "sounds": {
    "complete": "complete.mp3",
    "confirm": "confirm.mp3"
  },
  "objectScale": {
    "widthRatio": 1.9,
    "heightRatio": 1.3,
    "offsetX": -0.45,
    "offsetY": -0.25
  }
}
